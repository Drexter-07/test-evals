{
  "name": "test-evals",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @test-evals/db db:push",
    "db:studio": "turbo -F @test-evals/db db:studio",
    "db:generate": "turbo -F @test-evals/db db:generate",
    "db:migrate": "turbo -F @test-evals/db db:migrate",
    "eval": "bun run apps/server/src/cli/eval.ts"
  },
  "dependencies": {
    "@test-evals/env": "workspace:*",
    "dotenv": "^17.2.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@test-evals/config": "workspace:*",
    "@types/bun": "^1.3.4",
    "turbo": "^2.8.12",
    "typescript": "^6"
  },
  "packageManager": "bun@1.3.5"
}
